###################################################
# LMS Backend Environment (Production Example)
# Replace placeholders with real secure values.
###################################################

# ----------------------------
# Application
# ----------------------------
APP_NAME="Leave Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false

# ----------------------------
# Public URLs / Frontend Integration
# ----------------------------
APP_URL=https://lms.example.com
FRONTEND_URL=https://lms-frontend.example.com

# Comma-separated allowed browser origins for the frontend app(s).
CORS_ALLOWED_ORIGINS=https://lms-frontend.example.com,https://hrpds.example.com

#values that should receive Sanctum cookies.
SANCTUM_STATEFUL_DOMAINS=lms-frontend.example.com

SESSION_DOMAIN=.example.com
SESSION_SECURE_COOKIE=true

# ----------------------------
# Localization
# ----------------------------
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ----------------------------
# Maintenance / Security
# ----------------------------
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
API_RATE_LIMIT_PER_MINUTE=120

# ----------------------------
# Logging
# ----------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ----------------------------
# Database (SQL Server)
# ----------------------------
DB_CONNECTION=sqlsrv
DB_HOST=
DB_PORT=
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

HR_DB_CONNECTION=sqlsrv
HR_DB_HOST=
HR_DB_PORT=
HR_DB_DATABASE=
HR_DB_USERNAME=
HR_DB_PASSWORD=

# ----------------------------
# Session / Cache / Queue / Storage
# ----------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ----------------------------
# Mail
# ----------------------------
MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"
RESEND_API_KEY=

# ----------------------------
# SMS Gateway
# ----------------------------
# Example:
SMS_ENABLED=false
SMS_GATEWAY_URL=
SMS_TIMEOUT=8

# ----------------------------
# Frontend build
# ----------------------------
VITE_APP_NAME="${APP_NAME}"

# ----------------------------
# HR account seeding (production)
# ----------------------------
# Required for HRAccountSeeder.
HR_SEEDER_PASSWORD=
# Keep false to avoid overwriting existing HR passwords on re-seed.
HR_SEEDER_RESET_PASSWORDS=false
