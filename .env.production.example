APP_NAME="Leave Management System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false

APP_URL=https://lms.example.com
FRONTEND_URL=https://lms.example.com
CORS_ALLOWED_ORIGINS=https://lms.example.com
SANCTUM_STATEFUL_DOMAINS=lms.example.com
SANCTUM_TOKEN_EXPIRATION=120

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
API_RATE_LIMIT_PER_MINUTE=120

DB_CONNECTION=sqlsrv
DB_HOST=YOUR_SERVER_OR_INSTANCE
DB_PORT=
DB_DATABASE=LMS_DB
DB_USERNAME=YOUR_DB_USER
DB_PASSWORD=YOUR_DB_PASSWORD

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.example.com
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=smtp
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

RESEND_API_KEY=

VITE_APP_NAME="${APP_NAME}"

ERMS_API_KEY=
ERMS_ALLOWED_IPS=
